# Copy file này thành .env trên VPS nếu muốn đổi cấu hình.
NODE_ENV=production
HOST=0.0.0.0
PORT=4173
DATA_FILE=data/asean-hub.json
AUDIT_LOG_FILE=data/audit-log.jsonl
APP_SECRET=change-this-to-a-long-random-secret
SESSION_TTL_HOURS=12
PASSWORD_ITERATIONS=210000
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX=10
AUDIT_LOG_MAX_READ=500

# Sao luu ma hoa tu dong. Nen de passphrase trong file rieng co quyen 600.
BACKUP_DIR=/docker/backups/asean-english-hub/encrypted
BACKUP_PASSPHRASE_FILE=data/backup.passphrase
BACKUP_RETENTION_DAYS=30

# Email tự động gửi mật khẩu tạm khi admin tạo tài khoản giáo viên/học viên.
# Nếu chưa cấu hình SMTP_HOST, server vẫn tạo tài khoản và chỉ ghi email preview ra log.
SYSTEM_EMAIL_FROM="Asean Hitech System <no-reply@asean-vietnam.com>"
PUBLIC_APP_URL=https://asean-vietnam.com
SENDMAIL_PATH=/usr/sbin/sendmail
SMTP_HOST=smtp.your-domain.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_STARTTLS=true
SMTP_USER=no-reply@your-domain.com
SMTP_PASS=change-this-email-password

# Google Meet: tạo link Google Meet tự động cho từng buổi học.
# Tạo OAuth Client loại Web application trong Google Cloud Console và thêm redirect URI bên dưới.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://asean-vietnam.com/api/google/oauth/callback
GOOGLE_OAUTH_FILE=data/google-oauth.json
GOOGLE_MEET_ACCESS_TYPE=OPEN
GOOGLE_MEET_API_ENABLED=false
